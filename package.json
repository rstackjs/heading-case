{
  "name": "heading-case",
  "version": "1.1.3",
  "repository": "https://github.com/rstackjs/heading-case",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "heading-case": "./bin.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest",
    "bump": "npx bumpp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.6.5",
    "@rstest/core": "^0.11.1",
    "@types/node": "^24.13.3",
    "case-police": "^2.2.1",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "prettier": "^3.9.5",
    "rslog": "^2.2.0",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.17",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.13.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
